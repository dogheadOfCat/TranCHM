<Window x:Class="CHMConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="CHM 转换工具"
        Height="680" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        StateChanged="Window_StateChanged"
        SourceInitialized="Window_SourceInitialized">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="4"
                            GlassFrameThickness="0"
                            CornerRadius="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- 外层边框（代替系统窗口边线） -->
    <Border BorderBrush="#3A3A55" BorderThickness="1"
            Background="{DynamicResource BgDarkBrush}"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ==================== 自定义标题栏 ==================== -->
            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Background="{DynamicResource TitleBarBrush}"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：图标 + 标题 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="📄" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="CHM 转换工具"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右侧：主题切换 + 窗口控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- 主题选择下拉 -->
                    <Button x:Name="BtnThemeMenu"
                            Style="{StaticResource ThemeToggleButton}"
                            Click="BtnThemeMenu_Click"
                            ToolTip="选择主题">
                        <Path Data="M6,0 C10.4,0 14,3.6 14,8 C14,12.4 10.4,16 6,16 C3.3,16 1,14.2 0,11.8 L0,4.2 C1,1.8 3.3,0 6,0 Z M6,2 L6,14 C9.3,14 12,11.3 12,8 C12,4.7 9.3,2 6,2 Z"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="15" Height="15"
                              Stretch="Uniform"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ThemeContextMenu"
                                         Style="{StaticResource ThemeContextMenu}">
                                <MenuItem Header="暗紫  —  Dark Purple"
                                          Tag="DarkPurple"
                                          Click="ThemeMenuItem_Click"
                                          Style="{StaticResource ThemeMenuItem}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="14" Height="14" Fill="#6C5CE7"
                                                 Stroke="#8B7CF0" StrokeThickness="1"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="暗蓝  —  Dark Blue"
                                          Tag="DarkBlue"
                                          Click="ThemeMenuItem_Click"
                                          Style="{StaticResource ThemeMenuItem}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="14" Height="14" Fill="#4A90D9"
                                                 Stroke="#7AB8F5" StrokeThickness="1"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="亮色  —  Light Modern"
                                          Tag="LightModern"
                                          Click="ThemeMenuItem_Click"
                                          Style="{StaticResource ThemeMenuItem}">
                                    <MenuItem.Icon>
                                        <Ellipse Width="14" Height="14" Fill="#F5F5F8"
                                                 Stroke="#D4D4E0" StrokeThickness="1"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- 最小化 -->
                    <Button Style="{StaticResource TitleBarButton}"
                            Click="BtnMinimize_Click"
                            ToolTip="最小化">
                        <Path Data="M14,16 L32,16"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>

                    <!-- 最大化 / 还原 -->
                    <Button x:Name="BtnMaxRestore"
                            Style="{StaticResource TitleBarButton}"
                            Click="BtnMaxRestore_Click"
                            ToolTip="最大化">
                        <Grid>
                            <Path x:Name="IconMaximize"
                                  Data="M15,9 L31,9 L31,23 L15,23 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2"
                                  Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Path x:Name="IconRestore"
                                  Data="M13,12 L27,12 L27,24 L13,24 Z M19,8 L33,8 L33,20 L19,20 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2"
                                  Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Visibility="Collapsed"/>
                        </Grid>
                    </Button>

                    <!-- 关闭 -->
                    <Button Style="{StaticResource TitleBarCloseButton}"
                            Click="BtnClose_Click"
                            ToolTip="关闭">
                        <Path Data="M15,10 L31,24 M31,10 L15,24"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ==================== 主内容区 ==================== -->
            <Grid Grid.Row="1" Margin="24,16,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 副标题 -->
                <TextBlock Grid.Row="0"
                           Text="将 CHM 帮助文件批量转换为 HTML 网页"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,16"/>

                <!-- 操作按钮行 -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnSelectFiles"
                            Content="📁 选择 CHM 文件"
                            Width="160"
                            Click="BtnSelectFiles_Click"/>

                    <Button x:Name="BtnSelectOutput"
                            Grid.Column="1"
                            Content="📂 选择输出目录"
                            Width="160"
                            Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnSelectOutput_Click"/>

                    <Button x:Name="BtnClearFiles"
                            Grid.Column="2"
                            Content="清空列表"
                            Width="100"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnClearFiles_Click"/>
                </Grid>

                <!-- 文件列表 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="8"
                        Padding="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="12,10">
                            <TextBlock Text="📋 待转换文件 ("
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"/>
                            <TextBlock x:Name="TxtFileCount"
                                       Text="0"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                            <TextBlock Text=" 个)"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"/>
                        </StackPanel>

                        <ListBox x:Name="LstFiles"
                                 Grid.Row="1"
                                 MinHeight="120"
                                 MaxHeight="200"
                                 SelectionMode="Extended">
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 输出目录 -->
                <Border Grid.Row="3"
                        Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="📂 输出目录："
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="TxtOutputPath"
                                   Grid.Column="1"
                                   Text="（未选择）"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- 转换按钮和进度 -->
                <Grid Grid.Row="4" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnConvert"
                            Content="🚀 开始转换"
                            Width="160"
                            Height="44"
                            FontSize="15"
                            Click="BtnConvert_Click"/>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <ProgressBar x:Name="PrgBar"
                                     Width="Auto"
                                     Minimum="0" Maximum="100" Value="0"
                                     IsIndeterminate="False"/>
                        <TextBlock x:Name="TxtProgress"
                                   Text="就绪"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 统计信息 -->
                <Border Grid.Row="5"
                        Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="8"
                        Padding="16,10"
                        Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅ 成功: "
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtSuccessCount" Text="0"
                                   Foreground="{DynamicResource SuccessBrush}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="  ❌ 失败: "
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="20,0,0,0"/>
                        <TextBlock x:Name="TxtFailCount" Text="0"
                                   Foreground="{DynamicResource ErrorBrush}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="  ⏱ 用时: "
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="20,0,0,0"/>
                        <TextBlock x:Name="TxtElapsed" Text="--"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- 日志区域 -->
                <Border Grid.Row="6"
                        Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="8"
                        Padding="4"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="📝 运行日志"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"/>

                            <Button x:Name="BtnClearLog"
                                    Grid.Column="1"
                                    Content="清空"
                                    Width="60"
                                    Height="26"
                                    FontSize="11"
                                    Padding="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnClearLog_Click"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      x:Name="LogScrollViewer">
                            <ItemsControl x:Name="LogItemsControl"
                                          Margin="12,0,12,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"
                                                   FontFamily="Consolas, Microsoft YaHei" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="OK">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="ERR">
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
